rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isInitialSuperAdmin() {
      return isSignedIn() && (request.auth.token.email == 'iamzahidhb@etl.internal' || request.auth.token.email == 'iamzahidhb@gmail.com');
    }

    function isAdmin() {
      return isInitialSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin'));
    }

    function isSuperAdmin() {
      return isInitialSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin');
    }

    // Admins collection (deprecated, kept for compatibility if needed during migration)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Publicly readable collections, manageable by admins
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users collection - users can read their own, only Admins can manage
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin(); 
    }
    
    // Test collection for connectivity check
    match /test/connection {
      allow read: if true;
    }
  }
}
